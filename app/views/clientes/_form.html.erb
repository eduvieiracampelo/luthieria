<%= form_with(model: cliente, class: "contents") do |form| %>
  <% if cliente.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-4 py-3 rounded-md mb-4">
      <h2 class="font-medium"><%= pluralize(cliente.errors.count, "erro") %> impediu o salvamento:</h2>
      <ul class="list-disc ml-4 mt-1">
        <% cliente.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-lg shadow border border-gray-200 p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= form.label :nome, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :nome, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :telefone, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :telefone, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>
    </div>

    <div class="mt-4">
      <%= form.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.email_field :email, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="mt-4">
      <%= form.label :endereco, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.textarea :endereco, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="mt-6 flex gap-2">
      <%= form.submit (cliente.persisted? ? "Atualizar" : "Criar"), class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded cursor-pointer" %>
      <%= link_to "Cancelar", clientes_path, class: "bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded" %>
    </div>
  </div>
<% end %>
