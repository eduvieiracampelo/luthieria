<% content_for :title, "Clientes" %>

<div class="w-full">
  <div id="notice"></div>

  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Clientes</h1>
    <%= link_to "Novo Cliente", new_cliente_path, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
  </div>

  <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Nome</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Telefone</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Instrumentos</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200" id="clientes-list">
        <% @clientes.each do |cliente| %>
          <tr id="<%= dom_id(cliente) %>" class="hover:bg-gray-50">
            <td class="px-4 py-3 font-medium"><%= cliente.nome %></td>
            <td class="px-4 py-3"><%= cliente.telefone %></td>
            <td class="px-4 py-3"><%= cliente.email %></td>
            <td class="px-4 py-3"><span class="bg-blue-100 text-blue-800 text-xs font-medium px-2 py-1 rounded"><%= cliente.instrumentos.count %></span></td>
            <td class="px-4 py-3 flex gap-3">
              <%= link_to cliente, class: "text-blue-600 hover:text-blue-800", title: "Ver" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                </svg>
              <% end %>
              <%= link_to edit_cliente_path(cliente), class: "text-yellow-600 hover:text-yellow-800", title: "Editar" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                </svg>
              <% end %>
              <%= button_to cliente, method: :delete, data: { turbo_confirm: "Tem certeza?" }, class: "text-red-600 hover:text-red-800", title: "Excluir", form: { class: "inline" } do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                </svg>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @clientes.empty? %>
          <tr>
            <td colspan="5" class="px-4 py-8 text-center text-gray-500">Nenhum cliente cadastrado</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
