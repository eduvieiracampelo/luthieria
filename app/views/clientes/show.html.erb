<% content_for :title, "Cliente" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Cliente</h1>
    <div class="flex gap-2">
      <%= link_to "Editar", edit_cliente_path(@cliente), class: "bg-yellow-500 hover:bg-yellow-700 text-white font-bold py-2 px-4 rounded" %>
      <%= link_to "Voltar", clientes_path, class: "bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded" %>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
    <div class="p-6 space-y-4">
      <div>
        <p class="text-sm text-gray-500">Nome</p>
        <p class="text-lg font-medium"><%= @cliente.nome %></p>
      </div>
      <div>
        <p class="text-sm text-gray-500">Telefone</p>
        <p class="text-lg"><%= @cliente.telefone %></p>
      </div>
      <div>
        <p class="text-sm text-gray-500">Email</p>
        <p class="text-lg"><%= @cliente.email %></p>
      </div>
      <div>
        <p class="text-sm text-gray-500">Endereço</p>
        <p class="text-lg"><%= @cliente.endereco %></p>
      </div>
      <div>
        <p class="text-sm text-gray-500">Instrumentos</p>
        <p class="text-lg"><%= @cliente.instrumentos.count %></p>
      </div>
    </div>
  </div>

  <div class="mt-4">
    <%= button_to "Excluir", @cliente, method: :delete, data: { turbo_confirm: "Tem certeza?" }, class: "bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded" %>
  </div>
</div>
