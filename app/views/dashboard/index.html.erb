<div class="w-full">
  <div class="mb-6">
    <h1 class="text-2xl font-bold">Dashboard</h1>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-8">
    <div class="bg-white p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-sm">Clientes</p>
      <p class="text-3xl font-bold"><%= @total_clientes %></p>
    </div>
    <div class="bg-white p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-sm">Instrumentos</p>
      <p class="text-3xl font-bold"><%= @total_instrumentos %></p>
    </div>
    <div class="bg-white p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-sm">Serviços Pendentes</p>
      <p class="text-3xl font-bold text-yellow-600"><%= @servicos_pendentes %></p>
    </div>
    <div class="bg-white p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-sm">Serviços Concluídos</p>
      <p class="text-3xl font-bold text-green-600"><%= @servicos_concluidos %></p>
    </div>
    <div class="bg-white p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-sm">Receita Total</p>
      <p class="text-3xl font-bold text-green-600"><%= number_to_currency(@receita_total) %></p>
    </div>
  </div>

  <div class="mb-4">
    <input type="text" id="global-search" placeholder="Buscar clientes, instrumentos ou serviços..." class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
  </div>

  <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden" data-controller="global-search">
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tipo</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Nome/Descrição</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Detalhes</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200" id="itens-list">
        <% @itens.each do |item| %>
          <tr class="hover:bg-gray-50 search-item" data-search-text="<%= "#{item[:tipo]} #{item[:modelo]} #{item[:detalhes]}" %>">
            <td class="px-4 py-3">
              <% case item[:tipo] %>
              <% when "Cliente" %>
                <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2 py-1 rounded">Cliente</span>
              <% when "Instrumento" %>
                <span class="bg-purple-100 text-purple-800 text-xs font-medium px-2 py-1 rounded">Instrumento</span>
              <% when "Serviço" %>
                <span class="bg-green-100 text-green-800 text-xs font-medium px-2 py-1 rounded">Serviço</span>
              <% end %>
            </td>
            <td class="px-4 py-3 font-medium"><%= item[:modelo] %></td>
            <td class="px-4 py-3 text-gray-600"><%= item[:detalhes] %></td>
            <td class="px-4 py-3">
              <% if item[:tipo] == "Cliente" %>
                <%= link_to item[:item], class: "text-blue-600 hover:text-blue-800", title: "Ver" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
                <% end %>
              <% elsif item[:tipo] == "Instrumento" %>
                <%= link_to item[:item], class: "text-blue-600 hover:text-blue-800", title: "Ver" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
                <% end %>
              <% else %>
                <%= link_to edit_servico_path(item[:item]), class: "text-blue-600 hover:text-blue-800", title: "Ver" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @itens.empty? %>
          <tr><td colspan="4" class="px-4 py-8 text-center text-gray-500">Nenhum item encontrado</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
