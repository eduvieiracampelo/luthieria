<div class="w-full">
  <div class="mb-6">
    <h1 class="text-2xl font-bold">Dashboard</h1>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-8">
    <div class="bg-white p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-sm">Clientes</p>
      <p class="text-3xl font-bold"><%= @total_clientes %></p>
    </div>
    <div class="bg-white p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-sm">Instrumentos</p>
      <p class="text-3xl font-bold"><%= @total_instrumentos %></p>
    </div>
    <div class="bg-white p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-sm">Serviços Pendentes</p>
      <p class="text-3xl font-bold text-yellow-600"><%= @servicos_pendentes %></p>
    </div>
    <div class="bg-white p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-sm">Serviços Concluídos</p>
      <p class="text-3xl font-bold text-green-600"><%= @servicos_concluidos %></p>
    </div>
    <div class="bg-white p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-sm">Receita Total</p>
      <p class="text-3xl font-bold text-green-600"><%= number_to_currency(@receita_total) %></p>
    </div>
  </div>

  <div class="mb-4">
    <input type="text" id="global-search" placeholder="Buscar em clientes, instrumentos ou serviços..." class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
  </div>

  <div class="space-y-6" data-controller="global-search">
    <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
      <div class="p-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold">Clientes</h2>
      </div>
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Nome</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Telefone</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200" id="clientes-list">
          <% @clientes_recentes.each do |cliente| %>
            <tr class="hover:bg-gray-50 search-item" data-search-text="<%= "#{cliente.nome} #{cliente.email} #{cliente.telefone}" %>">
              <td class="px-4 py-3 font-medium"><%= cliente.nome %></td>
              <td class="px-4 py-3"><%= cliente.telefone %></td>
              <td class="px-4 py-3"><%= cliente.email %></td>
              <td class="px-4 py-3">
                <%= link_to cliente, class: "text-blue-600 hover:text-blue-800", title: "Ver" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @clientes_recentes.empty? %>
            <tr><td colspan="4" class="px-4 py-8 text-center text-gray-500">Nenhum cliente encontrado</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
      <div class="p-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold">Instrumentos</h2>
      </div>
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Modelo</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Marca</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tipo</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Cliente</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200" id="instrumentos-list">
          <% @instrumentos_recentes.each do |instrumento| %>
            <tr class="hover:bg-gray-50 search-item" data-search-text="<%= "#{instrumento.modelo} #{instrumento.marca} #{instrumento.tipo} #{instrumento.cliente.nome}" %>">
              <td class="px-4 py-3 font-medium"><%= instrumento.modelo %></td>
              <td class="px-4 py-3"><%= instrumento.marca %></td>
              <td class="px-4 py-3"><span class="bg-purple-100 text-purple-800 text-xs font-medium px-2 py-1 rounded"><%= instrumento.tipo %></span></td>
              <td class="px-4 py-3"><%= instrumento.cliente.nome %></td>
              <td class="px-4 py-3">
                <%= link_to instrumento, class: "text-blue-600 hover:text-blue-800", title: "Ver" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @instrumentos_recentes.empty? %>
            <tr><td colspan="5" class="px-4 py-8 text-center text-gray-500">Nenhum instrumento encontrado</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
      <div class="p-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold">Serviços</h2>
      </div>
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Serviço</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Cliente</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Instrumento</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Valor</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200" id="servicos-list">
          <% @servicos_recentes.each do |servico| %>
            <tr class="hover:bg-gray-50 search-item" data-search-text="<%= "#{servico.descricao} #{servico.cliente.nome} #{servico.instrumento.modelo}" %>">
              <td class="px-4 py-3"><%= servico.descricao %></td>
              <td class="px-4 py-3"><%= servico.cliente.nome %></td>
              <td class="px-4 py-3"><%= servico.instrumento.modelo %></td>
              <td class="px-4 py-3"><%= number_to_currency(servico.valor) %></td>
              <td class="px-4 py-3">
                <% if servico.concluido %>
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">Concluído</span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Pendente</span>
                <% end %>
              </td>
              <td class="px-4 py-3 flex gap-3">
                <%= link_to edit_servico_path(servico), class: "text-yellow-600 hover:text-yellow-800", title: "Editar" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" /></svg>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @servicos_recentes.empty? %>
            <tr><td colspan="6" class="px-4 py-8 text-center text-gray-500">Nenhum serviço encontrado</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
