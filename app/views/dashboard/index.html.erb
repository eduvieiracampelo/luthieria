<div class="w-full">
  <div class="mb-6">
    <h1 class="text-2xl font-bold">Dashboard</h1>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-5 gap-2 md:gap-4 mb-6 md:mb-8">
    <div class="bg-white p-3 md:p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-xs md:text-sm">Clientes</p>
      <p class="text-2xl md:text-3xl font-bold"><%= @total_clientes %></p>
    </div>
    <div class="bg-white p-3 md:p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-xs md:text-sm">Instrumentos</p>
      <p class="text-2xl md:text-3xl font-bold"><%= @total_instrumentos %></p>
    </div>
    <div class="bg-white p-3 md:p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-xs md:text-sm">Pendentes</p>
      <p class="text-2xl md:text-3xl font-bold text-yellow-600"><%= @servicos_pendentes %></p>
    </div>
    <div class="bg-white p-3 md:p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-xs md:text-sm">Concluídos</p>
      <p class="text-2xl md:text-3xl font-bold text-green-600"><%= @servicos_concluidos %></p>
    </div>
    <div class="col-span-2 md:col-span-1 bg-white p-3 md:p-6 rounded-lg shadow border border-gray-200">
      <p class="text-gray-500 text-xs md:text-sm">Receita</p>
      <p class="text-xl md:text-3xl font-bold text-green-600"><%= number_to_currency(@receita_total) %></p>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
    <div class="p-3 md:p-4 border-b border-gray-200 flex flex-col md:flex-row justify-between items-start md:items-center gap-2">
      <h2 class="text-lg font-semibold">Serviços</h2>
      <div class="flex flex-col sm:flex-row gap-2 w-full md:w-auto">
        <input type="text" id="search-servicos" placeholder="Buscar..." class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-full sm:w-48">
        <%= link_to "Novo", new_servico_path, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded text-center text-sm whitespace-nowrap" %>
      </div>
    </div>
    <div class="overflow-x-auto">
    <table class="w-full min-w-full" data-controller="servico-search">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Serviço</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Cliente</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Instrumento</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Valor</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Data Início</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @servicos.each do |servico| %>
          <tr id="<%= dom_id(servico) %>" class="hover:bg-gray-50 search-row" data-search-text="<%= "#{servico.descricao} #{servico.cliente.nome} #{servico.instrumento.modelo}".downcase %>">
            <td class="px-4 py-3 font-medium"><%= servico.descricao %></td>
            <td class="px-4 py-3"><%= servico.cliente.nome %></td>
            <td class="px-4 py-3"><%= servico.instrumento.modelo %></td>
            <td class="px-4 py-3"><%= number_to_currency(servico.valor) %></td>
            <td class="px-4 py-3"><%= I18n.l(servico.data_inicio) if servico.data_inicio %></td>
            <td class="px-4 py-3">
              <% if servico.concluido %>
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">Concluído</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Pendente</span>
              <% end %>
            </td>
            <td class="px-4 py-3 flex gap-3">
              <%= render "shared/action_buttons", model: servico, edit_path: edit_servico_path(servico) %>
            </td>
          </tr>
        <% end %>
        <% if @servicos.empty? %>
          <tr><td colspan="7" class="px-4 py-8 text-center text-gray-500">Nenhum serviço encontrado</td></tr>
        <% end %>
      </tbody>
    </table>
    </div>
  </div>
</div>
