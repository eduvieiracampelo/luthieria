<h2>Entrar</h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "contents" }) do |f| %>
  <div class="bg-white rounded-lg shadow border border-gray-200 p-6 mt-4">
    <div class="mb-4">
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, "Senha", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="mb-4 flex items-center gap-2">
        <%= f.check_box :remember_me, class: "h-4 w-4 text-blue-600 rounded" %>
        <%= f.label :remember_me, "Lembrar de mim", class: "text-sm text-gray-700" %>
      </div>
    <% end %>

    <div class="flex gap-2">
      <%= f.submit "Entrar", class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded cursor-pointer" %>
    </div>
  </div>
<% end %>

<%= render "devise/shared/links" %>
