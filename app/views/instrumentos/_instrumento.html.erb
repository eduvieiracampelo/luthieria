<div id="<%= dom_id instrumento %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Modelo:</strong>
    <%= instrumento.modelo %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Marca:</strong>
    <%= instrumento.marca %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Tipo:</strong>
    <%= instrumento.tipo %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Observacoes:</strong>
    <%= instrumento.observacoes %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Cliente:</strong>
    <%= instrumento.cliente.nome %>
  </div>
</div>
