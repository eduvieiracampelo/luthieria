<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Luthieria" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Luthieria">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" type="image/svg+xml" href="/icon.svg">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= turbo_include_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <nav class="fixed top-0 left-0 right-0 z-50 bg-gray-800 text-white p-4">
        <div class="container mx-auto flex justify-between items-center">
          <%= link_to "Luthieria Campelo", root_path, class: "text-xl font-bold" %>
          <div class="flex gap-4">
            <%= link_to "Dashboard", root_path, class: "hover:text-gray-300" %>
            <%= link_to "Clientes", clientes_path, class: "hover:text-gray-300" %>
            <%= link_to "Instrumentos", instrumentos_path, class: "hover:text-gray-300" %>
            <%= link_to "Serviços", servicos_path, class: "hover:text-gray-300" %>
            <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "hover:text-gray-300" %>
          </div>
        </div>
      </nav>
    <% else %>
      <nav class="fixed top-0 left-0 right-0 z-50 bg-gray-800 text-white p-4">
        <div class="container mx-auto flex justify-between items-center">
          <%= link_to "Luthieria Campelo", root_path, class: "text-xl font-bold" %>
          <div class="flex gap-4">
            <%= link_to "Entrar", new_user_session_path, class: "hover:text-gray-300" %>
          </div>
        </div>
      </nav>
    <% end %>

    <% if notice %><p class="notice bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4 mt-20"><%= notice %></p><% end %>
    <% if alert %><p class="alert bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4"><%= alert %></p><% end %>

    <main class="container mx-auto mt-20 px-5 pb-20">
      <%= yield %>
    </main>
  </body>
</html>
