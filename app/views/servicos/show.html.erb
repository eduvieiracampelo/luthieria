<% content_for :title, "Serviço" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Serviço</h1>
    <div class="flex gap-2">
      <%= link_to "Editar", edit_servico_path(@servico), class: "bg-yellow-500 hover:bg-yellow-700 text-white font-bold py-2 px-4 rounded" %>
      <%= link_to "Voltar", servicos_path, class: "bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded" %>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
    <div class="p-6 space-y-4">
      <div>
        <p class="text-sm text-gray-500">Descrição</p>
        <p class="text-lg font-medium"><%= @servico.descricao %></p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-gray-500">Cliente</p>
          <p class="text-lg"><%= link_to @servico.cliente.nome, @servico.cliente, class: "text-blue-600 hover:text-blue-800" %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Instrumento</p>
          <p class="text-lg"><%= link_to @servico.instrumento.modelo, @servico.instrumento, class: "text-blue-600 hover:text-blue-800" %></p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-gray-500">Valor</p>
          <p class="text-lg font-medium text-green-600"><%= number_to_currency(@servico.valor) %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Status</p>
          <p class="text-lg">
            <% if @servico.concluido %>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">Concluído</span>
            <% else %>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Pendente</span>
            <% end %>
          </p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-gray-500">Data Início</p>
          <p class="text-lg"><%= I18n.l(@servico.data_inicio) if @servico.data_inicio %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Data Conclusão</p>
          <p class="text-lg"><%= I18n.l(@servico.data_conclusao) if @servico.data_conclusao %></p>
        </div>
      </div>
      <div>
        <p class="text-sm text-gray-500">Observações</p>
        <p class="text-lg"><%= @servico.observacoes.presence || "-" %></p>
      </div>
    </div>
  </div>

  <div class="mt-4">
    <%= button_to "Excluir", @servico, method: :delete, data: { confirm: "Tem certeza?" }, class: "bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded" %>
  </div>
</div>
